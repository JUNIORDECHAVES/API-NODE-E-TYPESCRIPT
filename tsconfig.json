{
    "compilerOptions": {
        "rootDir": ".",
        "outDir": "./build",
        "moduleResolution": "nodenext",
        "module": "nodenext",
        "target": "es2022",
        "types": [
            "node",
            "jest"
        ],
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "noUncheckedIndexedAccess": true,
        "strict": true,
        "verbatimModuleSyntax": true,
        "isolatedModules": true,
        "noUncheckedSideEffectImports": true,
        "moduleDetection": "force",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "ignoreDeprecations": "6.0"
    },
    "include": [
        "src/**/*",
        "tests/**/*",
        "prisma.config.ts"
    ],
    "exclude": [
        "node_modules",
        "build",
        "eslint.config.ts",
        "jest.config.ts"
    ]
}